# vLLM Configuration for 8x H100 Deployment
# Copy this to .env and configure for your setup

# ============================================================================
# API Endpoints (vLLM)
# ============================================================================

# Base URL for vLLM (will be round-robin across 8 instances: 8000-8007)
LOCOTRAINER_BASE_URL=http://localhost:8000/v1

# Model name (must match vLLM deployment)
LOCOTRAINER_MODEL=LocoreMind/LocoTrainer-4B

# API key (use "local" for local vLLM, or your cloud API key)
LOCOTRAINER_API_KEY=local

# ============================================================================
# Agent Settings (for 200k context collection)
# ============================================================================

# Maximum agent turns per query (increased from default 20)
LOCOTRAINER_MAX_TURNS=40

# Max tokens per response (16k allows for long code reads)
LOCOTRAINER_MAX_TOKENS=16384

# Sampling parameters
LOCOTRAINER_TEMPERATURE=0.7
LOCOTRAINER_TOP_P=0.9

# ============================================================================
# Paths
# ============================================================================

# Path to ms-swift codebase (auto-cloned if missing)
LOCOTRAINER_CODEBASE=/workspace/ms-swift

# Output directory for trajectories
LOCOTRAINER_OUTPUT_DIR=./trajectories

# ============================================================================
# Optional: Cloud API Configuration (if not using local vLLM)
# ============================================================================
LOCOTRAINER_API_KEY=sk-your-key-here
LOCOTRAINER_BASE_URL=https://api.openai.com/v1
LOCOTRAINER_MODEL=gpt-4o

# ── Alternative: use standard OpenAI env vars ────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Agent settings ───────────────────────────────────────────────────────
LOCOTRAINER_MAX_TURNS=20
LOCOTRAINER_MAX_TOKENS=8192

# ── Sampling parameters ──────────────────────────────────────────────────
# Adjust these for vLLM or other inference engines
LOCOTRAINER_TEMPERATURE=0.7
LOCOTRAINER_TOP_P=0.9
LOCOTRAINER_FREQUENCY_PENALTY=0.0
LOCOTRAINER_PRESENCE_PENALTY=0.0

# ── Thinking mode (for Qwen, DeepSeek, etc.) ────────────────────────────
# LOCOTRAINER_ENABLE_THINKING=true
# LOCOTRAINER_THINKING_BUDGET=8192

# ── Paths ────────────────────────────────────────────────────────────────
# LOCOTRAINER_CODEBASE=/path/to/your/project
# LOCOTRAINER_OUTPUT_DIR=./output
